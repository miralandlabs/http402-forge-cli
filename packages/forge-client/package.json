{
  "name": "@http402/forge-client",
  "version": "0.1.1",
  "description": "TypeScript SDK for http402 Forge Digital Bazaar — buy, publish, delist, vault",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miraland-labs/http402-forge-cli.git",
    "directory": "packages/forge-client"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
